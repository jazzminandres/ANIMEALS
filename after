<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ANIMEALS | Profile Setup</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Outfit',sans-serif;
        }

        body{
            background:#fdfaf7;
            display:flex;
            justify-content:center;
            align-items:center;
            min-height:100vh;
            padding:20px;
            color:#2d2d2d;
        }

        .setup-box{
            background:#fff;
            padding:35px;
            border-radius:35px;
            box-shadow:0 15px 35px rgba(0,0,0,0.05);
            width:100%;
            max-width:500px;
            position:relative;
            margin-top:60px;
        }

        /* PROFILE PICTURE */
        .profile-header{
            position:absolute;
            top:-60px;
            left:50%;
            transform:translateX(-50%);
            width:120px;
            height:120px;
        }

        .profile-img{
            width:100%;
            height:100%;
            border-radius:50%;
            object-fit:cover;
            border:6px solid #fff;
            background:#eee;
            box-shadow:0 5px 15px rgba(0,0,0,0.1);
        }

        .edit-icon{
            position:absolute;
            bottom:5px;
            right:5px;
            background:#10b981;
            color:white;
            width:34px;
            height:34px;
            border-radius:50%;
            display:flex;
            align-items:center;
            justify-content:center;
            cursor:pointer;
            border:3px solid #fff;
            font-size:14px;
        }

        .title-area{
            text-align:center;
            margin-top:50px;
            margin-bottom:25px;
        }

        .title-area h2{ color:#0f7a4a; font-weight:800; }
        .title-area p{ font-size:13px; color:#999; }

        /* ROLE CARDS */
        .role-row{
            display:grid;
            grid-template-columns:repeat(3, 1fr);
            gap:10px;
            margin-bottom:25px;
        }

        .role-card{
            background:#f9f9f9;
            border:2px solid #eee;
            padding:12px;
            border-radius:18px;
            text-align:center;
            cursor:pointer;
            font-weight:700;
            font-size:13px;
            transition:0.3s;
        }

        .role-card.active{
            background:#10b981;
            color:white;
            border-color:#10b981;
        }

        /* FORM INPUTS */
        .form-grid{ display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:15px; }
        .form-full{ width:100%; margin-bottom:15px; }

        label{ display:block; margin-bottom:6px; font-weight:800; font-size:11px; color:#b0b0b0; text-transform:uppercase; letter-spacing:0.5px; }
        
        input, select{
            width:100%;
            padding:12px;
            background:#fcfcfc;
            border:1.5px solid #eee;
            border-radius:15px;
            outline:none;
            font-size:14px;
        }

        input:focus{ border-color:#10b981; }

        /* GENDER RESTROOM ICONS */
        .gender-row{ display:flex; gap:10px; }
        .gender-item{
            flex:1;
            border:1.5px solid #eee;
            border-radius:15px;
            padding:10px;
            display:flex;
            flex-direction:column;
            align-items:center;
            cursor:pointer;
            background:#fdfdfd;
            transition:0.2s;
        }

        .gender-item svg{ width:24px; height:24px; fill:#ccc; margin-bottom:4px; }
        .gender-item span{ font-size:10px; font-weight:800; color:#ccc; }

        .gender-item.active{ border-color:#10b981; background:#f0faf7; }
        .gender-item.active svg{ fill:#10b981; }
        .gender-item.active span{ color:#10b981; }

        /* FILE UPLOAD */
        .upload-wrapper{ position:relative; overflow:hidden; }
        .upload-btn{
            border:1.5px dashed #10b981;
            color:#10b981;
            background:#f0faf7;
            padding:10px;
            border-radius:15px;
            text-align:center;
            font-size:12px;
            font-weight:700;
            display:block;
            cursor:pointer;
        }
        .upload-wrapper input[type=file]{ position:absolute; inset:0; opacity:0; cursor:pointer; }

        .submit-btn{
            width:100%;
            background:#10b981;
            color:white;
            border:none;
            padding:15px;
            border-radius:18px;
            font-weight:800;
            font-size:15px;
            cursor:pointer;
            margin-top:10px;
            transition:0.3s;
        }

        .submit-btn:hover{ background:#0f7a4a; transform:translateY(-2px); }

        /* POPUP */
        .overlay{
            position:fixed;
            inset:0;
            background:rgba(0,0,0,0.4);
            display:none;
            justify-content:center;
            align-items:center;
            backdrop-filter:blur(5px);
            z-index:100;
        }
        .popup-card{ background:#fff; padding:35px; border-radius:30px; text-align:center; width:300px; }

    </style>
</head>
<body>

<div class="setup-box">
    <div class="profile-header">
        <img src="https://cdn-icons-png.flaticon.com/512/149/149071.png" id="avatarPreview" class="profile-img">
        <label class="edit-icon">
            <i class="bi bi-pencil-fill"></i>
            <input type="file" hidden accept="image/*" onchange="preview(event)">
        </label>
    </div>

    <div class="title-area">
        <h2>Profile Setup</h2>
        <p>Complete your information to continue</p>
    </div>

    <div class="role-row">
        <div class="role-card" onclick="setRole('student', this)">Student</div>
        <div class="role-card" onclick="setRole('seller', this)">Seller</div>
        <div class="role-card" onclick="setRole('admin', this)">Admin</div>
    </div>

    <form id="setupForm">
        <div id="dynamicFields">
            </div>
        <button type="button" id="doneBtn" class="submit-btn" style="display:none" onclick="openModal()">DONE</button>
    </form>
</div>

<div class="overlay" id="modalOverlay">
    <div class="popup-card" id="popupInner">
        <div class="bi bi-hourglass-split" style="color:#10b981; font-size:40px; margin-bottom:10px;"></div>
        <h3>Authenticating...</h3>
        <p style="color:#999; font-size:13px;">Please wait while we verify.</p>
    </div>
</div>

<script>
    function preview(e) {
        document.getElementById('avatarPreview').src = URL.createObjectURL(e.target.files[0]);
    }

    function pickGender(el) {
        document.querySelectorAll('.gender-item').forEach(i => i.classList.remove('active'));
        el.classList.add('active');
    }

    function setRole(role, btn) {
        document.querySelectorAll('.role-card').forEach(r => r.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('doneBtn').style.display = 'block';

        const genderSection = `
            <div class="form-full">
                <label>Gender</label>
                <div class="gender-row">
                    <div class="gender-item" onclick="pickGender(this)">
                        <svg viewBox="0 0 24 24"><path d="M12,2C10.34,2 9,3.34 9,5C9,6.66 10.34,8 12,8C13.66,8 15,6.66 15,5C15,3.34 13.66,2 12,2M10.5,22H13.5V15H14.5L14.75,10.23C14.89,7.66 13.11,5.5 10.5,5.5C7.89,5.5 6.11,7.66 6.25,10.23L6.5,15H7.5V22H10.5Z" /></svg>
                        <span>MALE</span>
                    </div>
                    <div class="gender-item" onclick="pickGender(this)">
                        <svg viewBox="0 0 24 24"><path d="M12,2C10.34,2 9,3.34 9,5C9,6.66 10.34,8 12,8C13.66,8 15,6.66 15,5C15,3.34 13.66,2 12,2M18,10.5C18,8.57 16.43,7 14.5,7H9.5C7.57,7 6,8.57 6,10.5L7,16H9V22H15V16H17L18,10.5Z" /></svg>
                        <span>FEMALE</span>
                    </div>
                </div>
            </div>`;

        const basic = `
            <div class="form-grid">
                <div><label>Name</label><input type="text" placeholder="Your Name"></div>
                <div><label>Email</label><input type="email" placeholder="email@sample.com"></div>
            </div>
            <div class="form-full"><label>Number</label><input type="tel" placeholder="09xxxxxxxxx"></div>`;

        let extra = '';
        if(role === 'student') {
            extra = `<div class="form-grid">
                <div><label>College</label><select><option>CEAT</option><option>CBAA</option><option>CTHM</option><option>CSCS</option></select></div>
                <div><label>Student #</label><input type="text" placeholder="2024XXXX"></div>
            </div>`;
        } else if(role === 'seller') {
            extra = `<div class="form-full"><label>Shop Name</label><input type="text" placeholder="Green Store"></div>
            <div class="form-grid">
                <div><label>Business Permit</label><div class="upload-wrapper"><span class="upload-btn">Upload</span><input type="file"></div></div>
                <div><label>Valid ID</label><div class="upload-wrapper"><span class="upload-btn">Upload</span><input type="file"></div></div>
            </div>`;
        } else {
            extra = `<div class="form-full"><label>Admin ID Document</label><div class="upload-wrapper"><span class="upload-btn">Choose File</span><input type="file"></div></div>`;
        }

        document.getElementById('dynamicFields').innerHTML = basic + extra + genderSection;
    }

    function openModal() {
        document.getElementById('modalOverlay').style.display = 'flex';
        setTimeout(() => {
            document.getElementById('popupInner').innerHTML = `
                <div class="bi bi-check-circle-fill" style="font-size: 50px; color: #10b981;"></div>
                <h3 style="margin-top:10px;">Success!</h3>
                <button class="submit-btn" onclick="location.reload()">Finish</button>`;
        }, 2000);
    }
</script>
</body>
</html>
